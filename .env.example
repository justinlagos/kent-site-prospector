# ============================================================
# Kent Site Prospector — environment configuration
# Copy to .env and fill in. See docs/api-integrations.md.
# ============================================================

# --- Core ---
APP_ENV=development                   # development | test | production
DATABASE_URL=postgresql://ksp:ksp_dev_password@localhost:5432/ksp
LOG_LEVEL=info
VAR_DIR=var                           # working dir for outbox/deploys/screenshots

# --- Agency identity (REQUIRED before any real email can be sent) ---
AGENCY_NAME=
AGENCY_WEBSITE=
AGENCY_PHONE=
AGENCY_POSTAL_ADDRESS=
AGENCY_SENDER_NAME=
AGENCY_SENDER_EMAIL=
AGENCY_REPLY_TO_EMAIL=

# --- Adapter selection: real | mock (production refuses mocks) ---
DIRECTORY_ADAPTER=mock
REGISTRY_ADAPTER=mock
EMAIL_VALIDATION_ADAPTER=mock
LLM_ADAPTER=mock
DEPLOY_ADAPTER=mock
EMAIL_PROVIDER_ADAPTER=mock

# --- Provider credentials (required when the matching adapter is `real`) ---
GOOGLE_PLACES_API_KEY=                # Google Cloud console -> Places API (New)
COMPANIES_HOUSE_API_KEY=              # developer.company-information.service.gov.uk
EMAIL_VALIDATION_API_KEY=             # ZeroBounce-compatible validation provider
EMAIL_VALIDATION_API_URL=
ANTHROPIC_API_KEY=                    # console.anthropic.com (when LLM_PROVIDER=anthropic)
ANTHROPIC_MODEL=claude-sonnet-4-5
LLM_PROVIDER=anthropic                # anthropic | openai-compatible
# openai-compatible works with free tiers: Gemini, Groq, OpenRouter, or local Ollama.
# Gemini example:
#   OPENAI_COMPAT_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
#   OPENAI_COMPAT_MODEL=gemini-2.0-flash
#   OPENAI_COMPAT_API_KEY=<AI Studio key from aistudio.google.com>
# Ollama example (free, fully local): base http://localhost:11434/v1, no key.
OPENAI_COMPAT_BASE_URL=
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=
IMAGE_ADAPTER=mock                    # real | mock | off — tailored concept imagery
IMAGE_PROVIDER=pollinations           # free, no API key required
NETLIFY_API_TOKEN=                    # app.netlify.com/user/applications
NETLIFY_ACCOUNT_SLUG=
POSTMARK_SERVER_TOKEN=                # postmarkapp.com server API token
POSTMARK_MESSAGE_STREAM=outbound
POSTMARK_WEBHOOK_TOKEN=               # random shared secret for webhook auth

# --- Email safety controls ---
EMAIL_DRY_RUN=true                    # default true: no real email leaves the system
EMAIL_KILL_SWITCH=false               # true halts ALL sending immediately
EMAIL_DOMAIN_AUTH_CONFIRMED=false     # set true ONLY after SPF+DKIM+DMARC verified
DAILY_FIRST_CONTACT_LIMIT=2
SEND_WINDOW_START_HOUR=10
SEND_WINDOW_END_HOUR=15

# --- Security (generate 32+ char random values for production) ---
SESSION_SECRET=dev-only-session-secret-change-me-0123456789
UNSUBSCRIBE_HMAC_SECRET=dev-only-unsub-secret-change-me-0123456789
DASHBOARD_BASE_URL=http://localhost:3000

# --- Retention / previews ---
PREVIEW_EXPIRY_DAYS=30
RETENTION_REJECTED_DAYS=90

# --- Monitoring ---
SENTRY_DSN=

# --- Initial admin (used once by db:seed; change password after first login) ---
INITIAL_ADMIN_EMAIL=admin@example.com
INITIAL_ADMIN_PASSWORD=change-me-immediately
